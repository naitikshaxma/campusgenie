# CampusGenie — Root Environment Configurations Guide
# Copy and populate these in their respective subdirectories.

# ==========================================
# BACKEND: Put inside backend/.env
# ==========================================
# PORT=8000
# NODE_ENV=development
# MONGO_URI=mongodb+srv://<username>:<password>@cluster0.s6ecjne.mongodb.net/campusgenie?retryWrites=true&w=majority
# JWT_SECRET=your_jwt_secret_key_here
# JWT_EXPIRES_IN=7d
# CORS_ORIGIN=http://localhost:5173
# GEMINI_API_KEY=your_gemini_api_key_here
# GEMINI_MODEL=gemini-2.5-flash
# UPLOAD_SIZE_LIMIT=5242880
# TZ=UTC

# ==========================================
# FRONTEND: Put inside frontend/.env
# ==========================================
# VITE_API_URL=http://localhost:8000/api
# VITE_APP_NAME=CampusGenie

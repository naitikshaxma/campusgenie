# CampusGenie — Root Environment Configurations Guide
# Copy and populate these in their respective subdirectories.

# ==========================================
# BACKEND: Put inside backend/.env
# ==========================================
# PORT=8000
# NODE_ENV=production
# TZ=UTC
# MONGO_URI=mongodb+srv://<username>:<password>@cluster.mongodb.net/campusgenie?retryWrites=true&w=majority
# JWT_SECRET=your_jwt_secret_key_here
# JWT_EXPIRES_IN=7d
# CORS_ORIGIN=https://your-vercel-domain.vercel.app
# OPENROUTER_API_KEY=your_openrouter_api_key_here
# OPENROUTER_MODEL=deepseek/deepseek-chat
# GROQ_API_KEY=your_groq_api_key_here
# GROQ_MODEL=llama-3.1-8b-instant
# OCR_SPACE_API_KEY=your_ocr_space_api_key_here
# UPLOAD_SIZE_LIMIT=5242880

# ==========================================
# FRONTEND: Put inside frontend/.env
# ==========================================
# VITE_API_URL=https://your-render-backend.onrender.com/api
# VITE_APP_NAME=CampusGenie
